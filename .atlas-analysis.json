    "./gradlew runApp",
    "./gradlew runUnitTests",
    "./gradlew runAcceptanceTests",
    "./gradlew testCoverage",
    "./gradlew staticCodeAnalysis",
    "default.json — build-time configuration flags",
    "custom-reloaded.json — white-label customization overrides",
    "CUSTOM_REPOSITORY / CUSTOM_FOLDER / CLIENT_FOLDER env vars — custom build injection",
    "com.wire.android.ui — Jetpack Compose UI layer",
    "com.wire.android.feature.e2ei — E2EI enrollment",
    "com.wire.android.emm — Enterprise Mobility Management",
