  "keyFeatures": [
    "End-to-end encrypted messaging (MLS and Proteus protocols)",
    "Voice and video calling with AVS (Audio-Video Signaling)",
    "Multi-account support (up to 3 accounts)",
    "Team collaboration with group conversations and channels",
    "Self-deleting messages and message reactions",
    "End-to-end identity (E2EI) certificate enrollment",
    "Enterprise Mobility Management (EMM) with managed configurations",
    "Legal hold compliance for enterprise deployments",
    "Cross-platform backup and restore",
    "Custom build flavors for white-label deployments",
    "F-Droid distribution (no closed-source dependencies)",
    "Biometric app lock"
  ],
  "publicApiSurface": [
